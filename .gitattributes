# Normalize line endings so the repo is consistent across Windows/macOS/Linux.
* text=auto eol=lf

# Windows-only launchers must stay CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Unix shell scripts must stay LF.
*.sh text eol=lf

# Binary assets — never line-ending-converted or diffed.
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ttf binary
*.woff binary
*.woff2 binary
